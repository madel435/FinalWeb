//Takes the name age and knowledge set

doctype html
html(lang="en")
  head
  
    title Finance IQ — Financial Knowledge Quiz
 
    style.

      :root {
        --accent: #8E758A;
        --bg: #FAF8F4;
        --card: #BAC6B2;
        --border: #BAC6B2;
        --text: #68405F;
        --muted: #858E7B;
        --radius: 14px;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Space Mono', monospace;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
      }

      .container {
        max-width: 600px;
        width: 100%;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 2.5rem;
        box-shadow: 0 0 40px rgba(142,117,138,0.08);
      }

      .logo {
        font-family: 'Syne', sans-serif;
        font-weight: 800;
        font-size: 2.6rem;
        background: linear-gradient(135deg, #8E758A, #C4B8D4);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 0.5rem;
      }

      .subtitle {
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--muted);
        font-size: 0.8rem;
        margin-bottom: 2rem;
      }

      .label {
        font-family: 'Syne', sans-serif;
        font-size: 1rem;
        margin-bottom: 0.6rem;
      }

      input, select {
        width: 100%;
        padding: 14px 16px;
        border-radius: 10px;
        border: 1px solid var(--border);
        background: #FAF8F4;
        color: var(--text);
        font-size: 0.9rem;
        margin-bottom: 1.8rem;
      }

      .rating-group {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }

      .rating-btn {
        padding: 12px 16px;
        border-radius: 10px;
        border: 1px solid var(--border);
        background: #FAF8F4;
        color: var(--text);
        cursor: pointer;
        text-align: left;
        font-size: 0.9rem;
        transition: 0.2s;
      }

      .rating-btn:hover {
        border-color: var(--accent);
      }

      .go-btn {
        margin-top: 2rem;
        width: 100%;
        padding: 14px 20px;
        border-radius: 50px;
        border: none;
        background: var(--accent);
        color: #FAF8F4;
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        cursor: pointer;
        font-size: 1rem;
        transition: 0.2s;
      }

      .go-btn:hover {
        transform: translateY(-2px);
      }

      .back-link {
        display: block;
        margin-top: 1.5rem;
        color: var(--muted);
        font-size: 0.85rem;
        text-decoration: none;
      }
  body
    .container
      .logo  Finance IQ
      p.subtitle FINANCIAL SELF ASSESSMENT

      // Name
      p.label WHAT’S YOUR NAME?
      input(type="text" placeholder="Enter your name...")

      // Generation
      p.label WHAT’S YOUR GENERATION?
      select
        option(value="Gen Z") Gen Z
        option(value="Millennial") Millennial
        option(value="Gen X") Gen X
        option(value="Baby Boomer") Baby Boomer
        option(value="Silent Gen") Silent Gen

      // Rating
      p.label WHICH BEST DESCRIBES YOUR KNOWLEDGE SET?
      .rating-group
        button.rating-btn  Zero clue
        button.rating-btn  Some basics
        button.rating-btn  Pretty solid
        button.rating-btn  Finance nerd

      a.back-link(href="/Quiz1/quiz1Q") ← Submit
      a.back-link(href="/") ← Back to Home
